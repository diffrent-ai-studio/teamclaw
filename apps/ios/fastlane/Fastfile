default_platform(:ios)

require "base64"

platform :ios do
  desc "Sync certificates and profiles via match"
  lane :sync_certs do
    match(type: "appstore", readonly: true)
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    manual_signing = !ENV["IOS_DISTRIBUTION_CERT_P12"].to_s.empty?
    setup_ci unless manual_signing

    key_content = ENV["ASC_KEY_CONTENT"].to_s
    is_key_content_base64 = !key_content.include?("BEGIN PRIVATE KEY")

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: key_content,
      is_key_content_base64: is_key_content_base64,
    )

    match(type: "appstore", readonly: true, api_key: api_key) unless manual_signing

    profile_name = ENV["IOS_PROVISIONING_PROFILE_NAME"] ||
      ENV["sigh_tech.teamclaw.mobile_appstore_profile-name"]

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "AMUX.xcodeproj",
      team_id: ENV["TEAM_ID"] || "43G5A6G9QV",
      bundle_identifier: "tech.teamclaw.mobile",
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
    )

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"],
      xcodeproj: "AMUX.xcodeproj",
    )

    build_app(
      project: "AMUX.xcodeproj",
      scheme: "AMUX",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "tech.teamclaw.mobile" => profile_name,
        },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
