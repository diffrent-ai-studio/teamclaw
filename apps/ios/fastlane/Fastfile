default_platform(:ios)

platform :ios do
  desc "Sync certificates and profiles via match"
  lane :sync_certs do
    match(type: "appstore", readonly: true)
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
    )

    match(type: "appstore", readonly: true, api_key: api_key)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "AMUX.xcodeproj",
      team_id: "43G5A6G9QV",
      bundle_identifier: "tech.teamclaw.mobile",
      code_sign_identity: "Apple Distribution",
      profile_name: ENV["sigh_tech.teamclaw.mobile_appstore_profile-name"],
    )

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"],
      xcodeproj: "AMUX.xcodeproj",
    )

    build_app(
      project: "AMUX.xcodeproj",
      scheme: "AMUX",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "tech.teamclaw.mobile" => ENV["sigh_tech.teamclaw.mobile_appstore_profile-name"],
        },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
